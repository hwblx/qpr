@startuml

/'
Class Diagram – Extended Relationships

Purpose:
Illustrates how multiple classes interact through various types of
relationships and cardinality.

*Relationships:
- Association (--): A structural relationship between classes
- Hidden Link (-[hidden]-): Used to influence layout positioning

*Features:
- package: Groups related classes into a namespace or module
- note: Adds explanatory text to packages or classes
'/

hide empty members

package "Identity" {
    class UserAccount {
        - username: string
        - password_hash: string
        # email_address: string
        + is_active: boolean
        
        + login(password: string): boolean
        + update_email(new_email: string): void
        # validate_format(data: string): boolean
        - hash_password(raw_password: string): string
    }

    class PremiumAccount {
        + billing_cycle: string
        + get_priority_support(): void
    }

    class Profile {
        + display_name: string
        + bio: string
        + update_profile(data: string): void
    }

    class Authenticator {
        - provider_name: string
        + verify_token(token: string): boolean
    }

    UserAccount <|-- PremiumAccount
    UserAccount *-- Profile
    UserAccount ..> Authenticator
}

package "Storage" {
    class UserRepository {
        + save(user: UserAccount): void
    }
    class DatabaseConnector {
        + connect(): void
    }
}

Identity -[hidden]right- Storage

UserAccount -- UserRepository : persists >
UserRepository -- DatabaseConnector : uses >

note top of Storage: Manages data persistence\nand connectivity.

@enduml
