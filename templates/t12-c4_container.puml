@startuml
!include <C4/C4_Context>
!include <C4/C4_Container>
' !include C4-PlantUML/C4_Context.puml
' !include C4-PlantUML/C4_Container.puml
!theme cloudscape-design
skinparam backgroundColor black
skinparam defaultFontColor white
skinparam package<<boundary>>BorderColor #00AEEF

/'
C2 – Container Diagram

Purpose:
Shows the high-level technical building blocks (*Containers) that make up
the Software System, their responsibilities, and how they communicate
with each other, with *People, and with *External Software Systems.

*Software System:
- IoT Sensor Network API: The system under consideration

*Containers:
- API Application: FastAPI application providing REST/WebSocket endpoints
- Database: TimescaleDB/PostgreSQL storing telemetry and metadata

*Relationships:
- API Application -> Database: Reads from and writes to via SQL
'/

System_Boundary(iot_api_system, "<color:#CCCCCC>IoT Sensor Network API</color>") <<boundary>> {
    Container(api_app, "API Application", "FastAPI", "Provides API endpoints for data collection, user management, and data retrieval")
    ContainerDb(database, "Database", "TimescaleDB/PostgreSQL", "Stores sensor telemetry, user profiles, and system configuration")
}

Rel(api_app, database, "Reads from\nand writes to", "SQL/TCP")
@enduml

