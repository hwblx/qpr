@startuml
!include <C4/C4_Deployment>
!theme cloudscape-design
skinparam backgroundColor #black
skinparam defaultFontColor #white

/'
C6 – Deployment Diagram

Purpose:
Illustrates the mapping of software containers to physical or virtual infrastructure.
Shows how the system is deployed across different environments and nodes.

*Nodes:
- Client Devices: Browser and IoT Gateway
- Cloud Provider (AWS/Azure/GCP): Hosting environment
- Virtual Private Cloud (VPC): Network isolation
- Auto-scaling Group: For API Application instances
- Managed Database Service: High-availability database

*Relationships:
- Communication protocols between nodes (HTTPS, MQTT, SQL/TCP)
'/

title Deployment Diagram - IoT Sensor Network API

Deployment_Node(client, "Client Environment", "User/Field Location") {
    Deployment_Node(browser_node, "User Device", "Windows/MacOS/Linux") {
        Container(browser, "Web Browser", "Chrome/Firefox", "User interface")
    }
    Deployment_Node(gateway_node, "Edge Device", "Raspberry Pi/Industrial PC") {
        Container(gateway, "IoT Gateway", "Python/C++", "Aggregates sensor data")
    }
}

Deployment_Node(cloud, "Cloud Provider", "AWS/Azure/GCP") {
    Deployment_Node(vpc, "Virtual Private Cloud", "10.0.0.0/16") {
        
        Deployment_Node(lb_node, "Load Balancer", "Nginx/ALB") {
            Container(lb, "Load Balancer", "Reverse Proxy", "Terminates SSL and routes traffic")
        }

        Deployment_Node(asg, "API Cluster", "Auto-scaling Group") {
            Deployment_Node(api_node_1, "API Node 1", "EC2/K8s Pod") {
                Container(api_instance_1, "API Application", "FastAPI", "Handles requests")
            }
            Deployment_Node(api_node_2, "API Node 2", "EC2/K8s Pod") {
                Container(api_instance_2, "API Application", "FastAPI", "Handles requests")
            }
        }

        Deployment_Node(db_node, "Database Server", "Managed Service (RDS)") {
            Deployment_Node(db_primary, "Primary Instance", "TimescaleDB") {
                ContainerDb(db_instance, "Database", "PostgreSQL", "Stores telemetry and metadata")
            }
        }
    }
}

Rel(browser, lb, "Sends requests to", "HTTPS/JSON")
Rel(gateway, lb, "Forwards data to", "HTTPS/MQTT")
Rel(lb, api_instance_1, "Routes to", "HTTP")
Rel(lb, api_instance_2, "Routes to", "HTTP")
Rel(api_instance_1, db_instance, "Reads/Writes", "SQL/TCP")
Rel(api_instance_2, db_instance, "Reads/Writes", "SQL/TCP")

@enduml
