@startuml

/'
Activity Diagram – Advanced Organization

Purpose:
Shows how to organize complex flows using swimlanes (lanes) and 
partitions to clarify responsibilities.

*Elements:
- |Lane|: Defines responsibility boundaries (swimlanes)
- partition: Groups related activities
- detach: Ends a specific branch without stopping the whole flow
'/

' Flat, clean styling with black relations
skinparam backgroundColor #4682b4
skinparam defaultFontName Segoe UI
skinparam shadowing false
skinparam roundcorner 10
skinparam ArrowColor #000000

skinparam activity {
  FontColor #ffffff
  BorderColor #1e293b
  BackgroundColor #334155
  DiamondFontColor #000000
  DiamondBackgroundColor #ffffff
  DiamondBorderColor #000000
  StartColor #22c55e
  EndColor #ef4444
}

skinparam partition {
  BorderColor #ff0000
  FontColor #ffffff
  BackgroundColor #78350f
}

title <color:#e2e8f0>Password Reset Flow</color>

' Light gray lanes
|#d1d5db|<color:#0f172a>User|
start <<#22c55e>>
:Request Password Reset; <<#475569>>

|#a3aedb|<color:#0f172a>System|
partition #f3f4f6 "<color:#0f172a>Validation</color>" {
  :Check Email Exists; <<#475569>>
  
  ' Diamond with black on white
  if (Exists?) then (no)
    :<b>Log Warning</b>; <<#dc2626>>
    detach
  else (yes)
  endif
  ' Restore defaults
  skinparam DiamondBackgroundColor #92400e
  skinparam DiamondFontColor #ffffff
}

:Generate Reset Token; <<#16a34a>>

|#d1d5db|<color:#0f172a>Email Service|
:Send Reset Email; <<#475569>>

|#d1d5db|<color:#0f172a>User|
:Click Reset Link; <<#475569>>
:Enter New Password; <<#475569>>

|#a3aedb|<color:#0f172a>System|
:Update Database; <<#16a34a>>
stop <<#ef4444>>

@enduml

