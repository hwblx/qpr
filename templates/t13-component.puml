@startuml
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>
' !include C4-PlantUML/C4_Context.puml
' !include C4-PlantUML/C4_Container.puml
' !include C4-PlantUML/C4_Component.puml
!theme cloudscape-design
skinparam backgroundColor #black
skinparam defaultFontColor #white

/'
C3 – Component Diagram

Purpose:
Shows the internal structure of a single *Container by decomposing it into
*Components, their responsibilities, and the relationships between them.

Scope:
- Exactly one *Container from the C2 Container Diagram
- The container is treated as the system boundary at this level

*Container:
- API Application (FastAPI)

*Components:
- Security Component: Handles JWT authentication and authorization
- Telemetry Controller: FastAPI routers for sensor data ingestion
- Management Controller: FastAPI routers for user and sensor management
- Data Processing Service: Business logic for validation and transformation
- Persistence Component: Repository layer for database interactions

*Relationships:
- External Systems -> Controllers: API requests
- Controllers -> Security: Auth checks
- Controllers -> Data Processing: Business logic execution
- Data Processing -> Persistence: Data storage and retrieval
- Persistence -> Database: SQL queries

'/

System_Ext(browser, "Browser", "Web interface used by people")
System_Ext(gateway, "IoT Gateway", "Aggregates and translates sensor data")
ContainerDb(database, "Database", "TimescaleDB/PostgreSQL", "Stores telemetry and metadata")

Container_Boundary(api_app, "API Application") {
    Component(security, "Security Component", "FastAPI Security", "Handles authentication and authorization")
    Component(telemetry_ctrl, "Telemetry Controller", "FastAPI Router", "Endpoints for sensor data ingestion")
    Component(mgmt_ctrl, "Management Controller", "FastAPI Router", "Endpoints for user and system management")
    Component(proc_service, "Data Processing Service", "Python Service", "Validates and transforms sensor data")
    Component(persistence, "Persistence Component", "SQLAlchemy/Repository", "Handles data access and persistence logic")
}

Rel(browser, mgmt_ctrl, "Manages system via", "HTTPS/JSON")
Rel(gateway, telemetry_ctrl, "Sends telemetry to", "MQTT/HTTPS")

Rel(mgmt_ctrl, security, "Uses")
Rel(telemetry_ctrl, security, "Uses")

Rel(mgmt_ctrl, proc_service, "Uses")
Rel(telemetry_ctrl, proc_service, "Uses")

Rel(proc_service, persistence, "Uses")
Rel(persistence, database, "Reads from and writes to", "SQL/TCP")

@enduml

