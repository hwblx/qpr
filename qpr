#!/bin/sh
# Render one or more PlantUML diagrams using Docker
# Usage:
#   qpr [options] <prefix-or-filename>...
# Options:
#   --png        Output PNG instead of SVG
#   --print      Display PNG in terminal (implies --png)
#   -q, --quiet  Suppress output messages
#   -h, --help   Show this help message
set -e

show_help() {
    echo "Usage: qpr [options] <prefix-or-filename>..."
    echo ""
    echo "Options:"
    echo "  --png        Output PNG instead of SVG"
    echo "  --print      Display PNG in terminal (implies --png)"
    echo "  -q, --quiet  Suppress output messages"
    echo "  -h, --help   Show this help message"
}

FORMAT="tsvg"
PRINT_IMAGE=false
QUIET=false
IMAGE="plantuml/plantuml:latest"

while [ $# -gt 0 ]; do
    case "$1" in
        --png)
            FORMAT="tpng"
            shift
            ;;
        --print)
            FORMAT="tpng"
            PRINT_IMAGE=true
            shift
            ;;
        -q|--quiet)
            QUIET=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        -*)
            echo "Unknown option: $1"
            show_help
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

if [ $# -eq 0 ]; then
    show_help
    exit 1
fi

if [ "$PRINT_IMAGE" = true ] && ! command -v kitten > /dev/null 2>&1; then
    echo "Error: 'kitten' command not found. Required for --print."
    exit 1
fi

if ! docker image inspect "$IMAGE" > /dev/null 2>&1; then
    echo "Docker image '$IMAGE' not found locally."
    printf "Do you want to pull it now? [y/N] "
    read -r REPLY
    case "$REPLY" in
        [Yy]*) ;;
        *) echo "Aborting."; exit 1 ;;
    esac
    docker pull "$IMAGE"
fi

# Collect files into positional parameters
TMP_FILES=""
for ARG in "$@"; do
    case "$ARG" in
        *.puml)
            if [ ! -f "$ARG" ]; then
                echo "Error: file '${ARG}' does not exist"
                exit 1
            fi
            TMP_FILES="${TMP_FILES}${ARG}
"
            ;;
        *)
            ARG_DIR=$(dirname "$ARG")
            ARG_BASE=$(basename "$ARG")
            BASE_FILE="${ARG}.puml"
            FOUND=false
            for f in "${ARG}"*.puml; do
                [ -e "$f" ] || continue
                FOUND=true
                break
            done
            if [ "$FOUND" = false ]; then
                echo "Error: no files matching '${ARG}*.puml'"
                exit 1
            fi
            [ -f "$BASE_FILE" ] && TMP_FILES="${TMP_FILES}${BASE_FILE}
"
            MATCHES=$(find "$ARG_DIR" -maxdepth 1 -name "${ARG_BASE}*.puml" | sort)
            for f in $MATCHES; do
                [ "$f" = "$BASE_FILE" ] && continue
                TMP_FILES="${TMP_FILES}${f}
"
            done
            ;;
    esac
done

# Set positional parameters to the collected files (unique)
# 'set --' clears existing arguments.
# 'IFS=' prevents trimming whitespace from filenames.
# 'read -r' handles backslashes correctly.
# The '<<EOF' block feeds the sorted, unique list of files into the loop.
set --
while IFS= read -r FILENAME; do
    [ -n "$FILENAME" ] && set -- "$@" "$FILENAME"
done <<EOF
$(echo "$TMP_FILES" | sort -u)
EOF

COUNT=$#

if [ "$QUIET" = "false" ]; then
    VERSION=$(docker run --rm "$IMAGE" plantuml -version | sed -n '1p')
    echo "Using $VERSION"
fi

for file in "$@"; do
    [ "$QUIET" = "false" ] && echo "Rendering $file ..."
    # Get absolute directory and filename
    FILE_DIR=$(cd "$(dirname "$file")" && pwd)
    FILE_NAME=$(basename "$file")

    docker run --rm \
      --user "$(id -u):$(id -g)" \
      -e HOME=/tmp \
      -e JAVA_TOOL_OPTIONS="-Duser.home=/tmp -Djava.io.tmpdir=/tmp" \
      -v "$FILE_DIR":/workspace \
      -w /workspace \
      "$IMAGE" \
      plantuml -${FORMAT} "$FILE_NAME" -o /workspace 2>&1 | grep -v "Picked up JAVA_TOOL_OPTIONS" || true

    if [ "$PRINT_IMAGE" = true ]; then
        PNG_FILE="${file%.puml}.png"
        [ -f "$PNG_FILE" ] && kitten icat "$PNG_FILE"
    fi
done

[ "$QUIET" = "false" ] && echo "Done! Rendered $COUNT diagram(s)."

